{
  "name": "biome-vscode",
  "displayName": "Biome Formatter",
  "version": "1.51.0",
  "description": "Biome linter and formatter integration",
  "categories": [
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "biomejs",
    "formatter",
    "linter",
    "biome"
  ],
  "bugs": {
    "url": "https://github.com/simwai/biome-vscode/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simwai/biome-vscode"
  },
  "publisher": "simwai",
  "main": "./out/main.js",
  "scripts": {
    "build": "pnpm run compile && pnpm run package",
    "compile": "rolldown -c rolldown.config.ts",
    "watch": "pnpm run compile --watch",
    "package": "vsce package --no-dependencies -o biome_formatter.vsix",
    "package:pre-release": "vsce package --no-dependencies --pre-release -o biome_formatter.vsix",
    "install-extension": "code --install-extension biome_formatter.vsix --force",
    "test": "cross-env TEST=true pnpm run compile && vscode-test",
    "test:unit": "cross-env TEST=true pnpm run compile && cross-env TEST_SUITE=unit vscode-test",
    "lint": "biome lint",
    "format": "biome check --write ."
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.1.0",
    "@types/vscode": "1.93.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "cross-env": "^10.1.0",
    "ovsx": "^0.10.9",
    "rolldown": "1.0.0-rc.12",
    "tinyglobby": "^0.2.15"
  },
  "contributes": {
    "commands": [
      {
        "command": "biome.restartServer",
        "title": "Restart Biome Server",
        "category": "Biome"
      },
      {
        "command": "biome.toggleEnable",
        "title": "Toggle whether Biome is enabled",
        "category": "Biome"
      },
      {
        "command": "biome.showOutputChannel",
        "title": "Show Output Channel",
        "category": "Biome"
      },
      {
        "command": "biome.applyAllFixesFile",
        "title": "Fix all auto-fixable problems (file)",
        "category": "Biome"
      },
      {
        "command": "biome.copyDebugInfo",
        "title": "Copy Debug Info",
        "category": "Biome"
      },
      {
        "command": "biome.rage",
        "title": "Rage (Debug Info)",
        "category": "Biome"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "biome",
      "properties": {
        "biome.enable": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Enable or disable Biome extension."
        },
        "biome.lint.run": {
          "scope": "resource",
          "type": "string",
          "enum": [
            "onSave",
            "onType"
          ],
          "default": "onType",
          "markdownDescription": "Run the linter on save (onSave) or on type (onType)"
        },
        "biome.requireConfig": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "markdownDescription": "Start the language server only when a `biome.json` or `biome.jsonc` file exists in one of the workspaces."
        },
        "biome.trace.server": {
          "type": "string",
          "scope": "window",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "markdownEnumDescriptions": [
            "No traces",
            "Error only",
            "Full log"
          ],
          "default": "off",
          "markdownDescription": "Traces the communication between VS Code and the language server."
        },
        "biome.configPath": {
          "type": [
            "string",
            "null"
          ],
          "scope": "resource",
          "default": null,
          "markdownDescription": "Path to biome configuration. Keep it empty to enable nested configuration."
        },
        "biome.disableNestedConfig": {
          "type": "boolean",
          "scope": "resource",
          "default": false,
          "markdownDescription": "Disable searching for nested configuration files."
        },
        "biome.path.biome": {
          "type": "string",
          "scope": "window",
          "markdownDescription": "Path to a Biome binary. Default: auto detection in `node_modules`."
        },
        "biome.path.node": {
          "type": "string",
          "scope": "window",
          "markdownDescription": "Path to a Node.js binary."
        },
        "biome.useExecPath": {
          "type": "boolean",
          "scope": "window",
          "default": false,
          "markdownDescription": "Whether to use the extension's execPath (Electron's bundled Node.js) as the JavaScript runtime for running Biome tools."
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "biome.json",
          "biome.jsonc"
        ],
        "url": "https://biomejs.dev/schemas/2.4.9/schema.json"
      }
    ],
    "languages": [
      {
        "id": "jsonc",
        "filenames": [
          "biome.json",
          "biome.jsonc"
        ]
      }
    ]
  },
  "activationEvents": [
    "onLanguage:astro",
    "onLanguage:css",
    "onLanguage:graphql",
    "onLanguage:html",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:less",
    "onLanguage:markdown",
    "onLanguage:mdx",
    "onLanguage:scss",
    "onLanguage:svelte",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:vue"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "packageManager": "pnpm@10.30.2",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "The Extension will always use the Language Server shipped with the Extension.",
      "restrictedConfigurations": [
        "biome.path.biome",
        "biome.path.node",
        "biome.useExecPath"
      ]
    }
  },
  "vsce": {
    "dependencies": false
  }
}